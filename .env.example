# Copy to .env for local overrides. The docker-compose stack supplies these same
# defaults inline, so a clean `docker compose up` works without a .env.

# --- Database ---
POSTGRES_USER=tovira
POSTGRES_PASSWORD=tovira
POSTGRES_DB=tovira
DB_PORT=5432

# Connection string used by the API (host `db` inside compose, `localhost` outside).
DATABASE_URL=postgres://tovira:tovira@localhost:5432/tovira

# Non-superuser role the API uses for request queries so Postgres RLS is enforced
# (created by migration 0003). Leave unset to fall back to DATABASE_URL.
APP_DATABASE_URL=postgres://tovira_app:tovira_app@localhost:5432/tovira
APP_DB_PASSWORD=tovira_app

# --- API ---
NODE_ENV=development
PORT=3001
API_PORT=3001

# --- Auth (P0-3) ---
# memory = ephemeral in-process store; postgres = durable (default for the app).
AUTH_STORE=postgres
SESSION_TTL_HOURS=168

# --- Transcription (P1-5) ---
# stub = canned transcript (no key); groq = real Whisper (needs GROQ_API_KEY).
TRANSCRIBER=stub
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3

# --- Cloud adapters (P6-2): stub locally, real when configured ---
# Embeddings: stub | bedrock (Titan v2; needs AWS creds + BEDROCK_REGION).
EMBEDDER=stub
BEDROCK_REGION=us-east-1
EMBED_MODEL=amazon.titan-embed-text-v2:0
# Web Push: stub | webpush (needs VAPID keys — generate with `web-push generate-vapid-keys`).
PUSH_SENDER=stub
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@tovira.local
# Stripe (TEST MODE ONLY — sk_test_...). Real gateway used when STRIPE_SECRET_KEY is set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_test
STRIPE_PRICE_ID=price_test
STRIPE_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CANCEL_URL=http://localhost:5173/billing/cancel

# --- Web ---
WEB_PORT=5173
